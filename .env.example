# Erato — Umgebungsvariablen (Vorlage). Kopiere nach `.env` und setze echte Werte.
# `.env` ist gitignored. Für Produktion: starke, eindeutige Passwörter verwenden.

# PostgreSQL
POSTGRES_USER=erato
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=erato

# MinIO (Object-Storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio-8+chars

# Keycloak Bootstrap-Admin (nur Erstinitialisierung)
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=change-me-keycloak

# Öffentliche Hosts (Produktion: echte Domains; Dev: localhost)
# Wird vom Prod-Override (docker-compose.prod.yml) genutzt.
PUBLIC_WEB_ORIGIN=http://localhost:8088
OIDC_PUBLIC_ISSUER=http://localhost:8085/realms/erato
